# ─── Luna Cycle Tracker – Environment Variables ──────────────────────────────
#
# Copy this file to .env.local and fill in your values.
# The app works fully in LOCAL MODE without any of these set.
#

# ─── Supabase (optional) ──────────────────────────────────────────────────────
# If set, enables cloud sync and auth. Leave empty for local-only mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Push Notifications (optional) ───────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID=
